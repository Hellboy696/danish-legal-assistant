# ═══════════════════════════════════════════════════════════════════
# Danish Legal Assistant V2 — Environment Configuration
# ═══════════════════════════════════════════════════════════════════
# Copy this file to backend/.env and fill in your values:
#   cp backend/.env.example backend/.env
#
# ⚠️  Never commit your .env file to version control!
# ═══════════════════════════════════════════════════════════════════

# ── Environment ──────────────────────────────────────────────────────────────
# Options: development | staging | production
ENV=development

# ── Claude AI (required for LLM-powered answers) ─────────────────────────────
# Get your key: https://console.anthropic.com/account/keys
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# Optional LLM overrides
# LLM_MODEL=claude-sonnet-4-5-20250929
# LLM_MAX_TOKENS=1024
# LLM_TEMPERATURE=0.3
# MAX_CONVERSATION_TURNS=10

# ── Redis Cache (optional, enables response caching) ─────────────────────────
# Local dev: redis://localhost:6379
# Docker:    redis://redis:6379
# Railway:   filled automatically from Railway Redis plugin
# REDIS_URL=redis://localhost:6379

# ── CORS (production: set to your actual frontend URL) ───────────────────────
# CORS_ORIGINS=["https://your-domain.com","https://www.your-domain.com"]

# ── Rate limiting ─────────────────────────────────────────────────────────────
# RATE_LIMIT=20/minute

# ── Monitoring (optional) ─────────────────────────────────────────────────────
# Get DSN at: https://sentry.io
# SENTRY_DSN=https://your-key@o0.ingest.sentry.io/0

# LOG_LEVEL=info
